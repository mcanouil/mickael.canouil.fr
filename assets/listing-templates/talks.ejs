<%
// =============================================================================
// Talks listing — year-grouped list with action buttons + chips.
// Items declared inline in talks.qmd; no individual talk pages.
// =============================================================================

function getYear(item) {
  const d = item.date ? new Date(item.date) : null;
  return d && !isNaN(d) ? String(d.getFullYear()) : null;
}

const grouped = {};
for (const it of items) {
  const y = getYear(it) || "Undated";
  if (!grouped[y]) grouped[y] = [];
  grouped[y].push(it);
}
const years = Object.keys(grouped).sort((a, b) => {
  if (a === "Undated") return 1;
  if (b === "Undated") return -1;
  return b.localeCompare(a);
});

const ICON = {
  slides:  '<iconify-icon icon="fa7-solid:person-chalkboard" aria-hidden="true"></iconify-icon>',
  code:    '<iconify-icon icon="octicon:mark-github-16" aria-hidden="true"></iconify-icon>',
  video:   '<iconify-icon icon="fa7-solid:circle-play" aria-hidden="true"></iconify-icon>',
  blog:    '<iconify-icon icon="fa7-solid:newspaper" aria-hidden="true"></iconify-icon>',
  meetup:  '<iconify-icon icon="fa7-brands:meetup" aria-hidden="true"></iconify-icon>'
};

const LABEL = {
  slides: "Slides",
  code:   "Code",
  video:  "Video",
  blog:   "Blog",
  meetup: "Meetup"
};
%>

<% years.forEach(year => {
  const list = grouped[year];
%>

```{=html}
<section id="talks-<%= year %>" class="talks-section">
  <h2 class="talks-year-header">
    <span class="talks-year"><%= year %></span>
    <span class="talks-year-count"><%= list.length %> talk<%= list.length === 1 ? "" : "s" %></span>
  </h2>
  <ul class="talks-list">
<% list.forEach(item => { %>
    <li class="talks-row" <%= metadataAttrs(item) %>>
      <div class="talks-main">
        <h3 class="talks-title"><%= item.title %></h3>
<% if (item.venue) { %>
        <p class="talks-venue"><%= item.venue %></p>
<% } %>
<% if (item.description) { %>
        <p class="talks-description"><%= item.description %></p>
<% } %>
        <div class="talks-actions">
<% ["slides","code","video","blog","meetup"].forEach(key => { %>
<% if (item[key]) { %>
          <a class="talks-button talks-button--<%= key %>" href="<%- item[key] %>" target="_blank" rel="noopener noreferrer"><%- ICON[key] %><span><%= LABEL[key] %></span></a>
<% } %>
<% }); %>
        </div>
<% if (item.categories && item.categories.length) { %>
        <div class="talks-categories">
<% for (const category of item.categories) { %>
          <span class="talks-category" onclick="window.quartoListingCategory('<%= utils.b64encode(category) %>'); return false;"><%= category %></span>
<% } %>
        </div>
<% } %>
      </div>
      <time class="talks-date" datetime="<%= item.date %>"><%= item.date %></time>
    </li>
<% }); %>
  </ul>
</section>
```

<% }); %>
