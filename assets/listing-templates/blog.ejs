<%
// =============================================================================
// Blog listing — hero (latest) + condensed magazine rows.
// items[0]   → .blog-hero (image left, oversized title, "Latest" pill).
// items[1..] → .blog-row.blog-row--compact (smaller thumb, tighter padding).
// =============================================================================
%>

```{=html}
<div class="list blog-list">
<% items.forEach((item, i) => { %>
<% if (i === 0) { %>
  <article class="blog-hero" <%= metadataAttrs(item) %>>
    <a class="blog-hero-thumb" href="<%- item.path %>" aria-hidden="true" tabindex="-1">
<% if (item.image) { %>
      <img src="<%= item.image %>" alt="" loading="lazy">
<% } else { %>
      <span class="blog-thumb-fallback" aria-hidden="true">M</span>
<% } %>
    </a>
    <div class="blog-hero-meta">
      <div class="blog-hero-eyebrow">
        <span class="blog-hero-badge">Latest</span>
        <time class="blog-date" datetime="<%= item.date %>"><%= item.date %></time>
      </div>
      <a class="blog-title-link" href="<%- item.path %>">
        <h2 class="blog-hero-title no-anchor">
```

<%= item.title %>

```{=html}
        </h2>
      </a>
<% if (item.description) { %>
      <div class="blog-hero-lead">
```

<%= item.description %>

```{=html}
      </div>
<% } %>
<% if (item.categories && item.categories.length) { %>
      <div class="blog-categories">
<% for (const category of item.categories) { %>
        <span class="blog-category" onclick="window.quartoListingCategory('<%= utils.b64encode(category) %>'); return false;"><%= category %></span>
<% } %>
      </div>
<% } %>
    </div>
  </article>
<% } else { %>
  <article class="blog-row blog-row--compact" <%= metadataAttrs(item) %>>
    <a class="blog-thumb" href="<%- item.path %>" aria-hidden="true" tabindex="-1">
<% if (item.image) { %>
      <img src="<%= item.image %>" alt="" loading="lazy">
<% } else { %>
      <span class="blog-thumb-fallback" aria-hidden="true">M</span>
<% } %>
    </a>
    <div class="blog-meta">
      <time class="blog-date" datetime="<%= item.date %>"><%= item.date %></time>
      <a class="blog-title-link" href="<%- item.path %>">
        <h3 class="blog-title no-anchor">
```

<%= item.title %>

```{=html}
        </h3>
      </a>
<% if (item.description) { %>
      <div class="blog-lead">
```

<%= item.description %>

```{=html}
      </div>
<% } %>
<% if (item.categories && item.categories.length) { %>
      <div class="blog-categories">
<% for (const category of item.categories) { %>
        <span class="blog-category" onclick="window.quartoListingCategory('<%= utils.b64encode(category) %>'); return false;"><%= category %></span>
<% } %>
      </div>
<% } %>
    </div>
  </article>
<% } %>
<% }) %>
</div>
```
