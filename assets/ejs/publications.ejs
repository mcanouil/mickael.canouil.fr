<%
const SELF_FAMILY = "Canouil";
const SELF_GIVEN = "Mickaël";

const TYPE_LABELS = {
  article: "Article",
  preprint: "Preprint",
  chapter: "Chapter",
  conf: "Conf.",
};

const TYPE_PLURAL = {
  article: ["article", "articles"],
  preprint: ["preprint", "preprints"],
  chapter: ["chapter", "chapters"],
  conf: ["conference paper", "conference papers"],
};

const NUMBER_WORDS = ["zero", "one", "two", "three", "four", "five", "six", "seven", "eight", "nine"];

const AUTHOR_LIST_LIMIT = 30;

function spellCount(n) {
  return n < NUMBER_WORDS.length ? NUMBER_WORDS[n] : String(n);
}

function escapeHtml(s) {
  return String(s == null ? "" : s)
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#39;");
}

function authorName(a) {
  const family = a.family || "";
  const particle = a["dropping-particle"] || a["non-dropping-particle"] || "";
  const given = a.given || "";
  const initials = given
    .split(/[\s\-]+/)
    .filter(Boolean)
    .map((p) => p.charAt(0).toUpperCase() + ".")
    .join(" ");
  const fullFamily = particle ? `${particle} ${family}` : family;
  return { family, given, fullFamily, initials };
}

function decodeAuthors(b64) {
  if (!b64) return [];
  try {
    const bin = atob(b64);
    const bytes = new Uint8Array(bin.length);
    for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
    return JSON.parse(new TextDecoder().decode(bytes));
  } catch (e) {
    return [];
  }
}

function authorHtml(a) {
  if (a.literal) {
    return `<span class="pub-author--literal">${escapeHtml(a.literal)}</span>`;
  }
  const { family, given, fullFamily, initials } = authorName(a);
  if (!fullFamily && !initials) return "";
  const display = initials ? `${fullFamily}, ${initials}` : fullFamily;
  const isSelf = family === SELF_FAMILY && given.startsWith(SELF_GIVEN);
  return isSelf
    ? `<strong class="pub-author--self">${escapeHtml(display)}</strong>`
    : escapeHtml(display);
}

function renderAuthors(authors) {
  if (!authors || authors.length === 0) return "";
  const total = authors.length;
  if (total <= AUTHOR_LIST_LIMIT) {
    return authors.map(authorHtml).filter(Boolean).join(", ");
  }

  const lastIdx = total - 1;
  const selfIdx = authors.findIndex((a) =>
    (a.family || "") === SELF_FAMILY && (a.given || "").startsWith(SELF_GIVEN)
  );

  const keep = new Set([0, 1, 2, lastIdx]);
  if (selfIdx >= 0) keep.add(selfIdx);
  const sorted = [...keep].sort((a, b) => a - b);

  const parts = [];
  let prev = -1;
  for (const i of sorted) {
    if (prev >= 0 && i > prev + 1) parts.push('<span class="pub-authors-ellipsis">…</span>');
    const html = authorHtml(authors[i]);
    if (html) parts.push(html);
    prev = i;
  }
  return parts.join(", ");
}

function getYear(item) {
  if (item.year) return String(item.year);
  if (item.issued) return String(item.issued).split("-")[0];
  if (item.date) return String(item.date).split("-")[0];
  return "Unknown";
}

function stripStars(s) {
  return String(s == null ? "" : s).replace(/\*/g, "");
}

function titleCase(s) {
  return String(s == null ? "" : s).replace(/(^|[\s\-\(\[\{:;])([a-z])/g, (_, sep, c) => sep + c.toUpperCase());
}

function venueText(item) {
  const journal = stripStars(item["journal-title"] || item["container-title"] || "");
  const meta = [];
  if (item.volume) meta.push(`vol. ${item.volume}`);
  if (item.issue) meta.push(`no. ${item.issue}`);
  if (item.page) meta.push(`pp. ${item.page}`);
  if (item["publisher-place"]) meta.push(item["publisher-place"]);
  return { journal, meta: meta.join(", ") };
}

function formatDate(item) {
  if (item["pub-date-label"]) return String(item["pub-date-label"]);
  return getYear(item);
}

function entryHtml(item) {
  const bibtype = item.bibtype || "article";
  const typeLabel = TYPE_LABELS[bibtype] || "Article";
  const venue = venueText(item);
  const dateLabel = formatDate(item);
  const isFirst = String(item.first || "").includes("first");
  const isLast = String(item.last || "").includes("last");
  const titleText = titleCase(stripStars(item.title || ""));
  const linkTarget = item.path || item.url;
  const doi = item.doi;
  const url = item.url;
  const pdfUrl = item["pdf-url"];
  const codeUrl = item["code-url"];
  const slidesUrl = item["slides-url"];
  const bibtex = item.bibtex;

  const head = [
    `<span class="pub-badge pub-badge--${bibtype}">${escapeHtml(typeLabel)}</span>`,
  ];
  if (isFirst) head.push(`<span class="pub-mark pub-mark--first" title="As first or co-first author">★ first</span>`);
  if (isLast) head.push(`<span class="pub-mark pub-mark--last" title="As last or co-last author">★ last</span>`);
  if (item.position) head.push(`<span class="pub-position" title="Author position">${escapeHtml(item.position)}</span>`);
  if (dateLabel) head.push(`<time class="pub-date">${escapeHtml(dateLabel)}</time>`);

  const titleHtml = linkTarget
    ? `<a href="${escapeHtml(linkTarget)}" rel="noopener noreferrer" target="_blank">${escapeHtml(titleText)}</a>`
    : escapeHtml(titleText);

  const venueHtml = venue.journal
    ? `<p class="pub-venue"><em>${escapeHtml(venue.journal)}</em>${venue.meta ? `, <span class="pub-venue-meta">${escapeHtml(venue.meta)}</span>` : ""}</p>`
    : "";

  const chips = [];
  if (doi) chips.push(`<a class="pub-chip" href="https://doi.org/${escapeHtml(doi)}" rel="noopener noreferrer" target="_blank">DOI</a>`);
  if (url && url !== `https://doi.org/${doi}`) {
    chips.push(`<a class="pub-chip" href="${escapeHtml(url)}" rel="noopener noreferrer" target="_blank">Article</a>`);
  }
  if (pdfUrl) chips.push(`<a class="pub-chip" href="${escapeHtml(pdfUrl)}" rel="noopener noreferrer" target="_blank">PDF</a>`);
  if (codeUrl) chips.push(`<a class="pub-chip" href="${escapeHtml(codeUrl)}" rel="noopener noreferrer" target="_blank">Code</a>`);
  if (slidesUrl) chips.push(`<a class="pub-chip" href="${escapeHtml(slidesUrl)}" rel="noopener noreferrer" target="_blank">Slides</a>`);
  if (bibtex) chips.push(`<button type="button" class="pub-chip pub-chip--bibtex" data-bibtex="${escapeHtml(bibtex)}" aria-label="Copy BibTeX entry">BibTeX</button>`);

  const authors = renderAuthors(decodeAuthors(item["pub-author"]));

  return [
    `<article class="pub-entry" data-bibtype="${escapeHtml(bibtype)}">`,
    `  <div class="pub-entry-head">${head.join("")}</div>`,
    `  <p class="pub-authors">${authors}</p>`,
    `  <h3 class="pub-title no-anchor">${titleHtml}</h3>`,
    venueHtml ? `  ${venueHtml}` : "",
    `  <nav class="pub-actions" aria-label="Publication actions">${chips.join("")}</nav>`,
    `</article>`,
  ].filter(Boolean).join("\n");
}

const groups = new Map();
for (const item of items) {
  const y = getYear(item);
  if (!groups.has(y)) groups.set(y, []);
  groups.get(y).push(item);
}
const yearOrder = [...groups.keys()].sort((a, b) => b.localeCompare(a));
%>

```{=html}
<section class="publications-list">
<nav class="pub-timeline" aria-label="Publications timeline">
  <ol class="pub-timeline-list">
<% const timelineOrder = [...yearOrder].reverse(); %>
<% for (const year of timelineOrder) {
  const yEntries = groups.get(year);
  const yTotal = yEntries.length;
%>
    <li class="pub-timeline-item">
      <a class="pub-timeline-link" href="#pub-year-<%- year %>">
        <span class="pub-timeline-year"><%- year %></span>
        <span class="pub-timeline-tick" aria-hidden="true"></span>
        <span class="pub-timeline-count"><%- yTotal %></span>
      </a>
    </li>
<% } %>
  </ol>
</nav>
<% for (const year of yearOrder) {
  const entries = groups.get(year);
  const total = entries.length;
  const typeCounts = {};
  for (const it of entries) {
    const t = it.bibtype || "article";
    typeCounts[t] = (typeCounts[t] || 0) + 1;
  }
  const breakdown = Object.entries(typeCounts)
    .sort((a, b) => b[1] - a[1])
    .map(([t, n]) => {
      const [s, p] = TYPE_PLURAL[t] || [t, t + "s"];
      return `${n} ${n === 1 ? s : p}`;
    })
    .join(" · ");
  const countLabel = `${spellCount(total)} ${total === 1 ? "publication" : "publications"}`;
%>
<header class="pub-year" id="pub-year-<%- year %>">
  <span class="pub-year-num"><%- year %></span>
  <span class="pub-year-count"><%- countLabel %></span>
  <span class="pub-year-types"><%- breakdown %></span>
</header>
<div class="pub-grid">
<% for (const item of entries) { %>
<%= entryHtml(item) %>
<% } %>
</div>
<% } %>
</section>
```
